# Postgres connection (api)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tracksub

# better-auth
# `openssl rand -base64 32` ile üret
BETTER_AUTH_SECRET=replace-me-with-32-bytes-of-random-data
BETTER_AUTH_URL=http://localhost:4000

# Ports
API_PORT=4000
WEB_PORT=3000
WEB_ORIGIN=http://localhost:3000

# fal.ai (zorunlu — AI paste/parse + Gmail mail analizi için)
# https://fal.ai/dashboard/keys
FAL_KEY=
# Default model — fal-ai/any-llm endpoint için openrouter-style id
AI_MODEL=google/gemini-2.5-flash

# Google OAuth (Gmail okuma + gönderme; reminder maili de bu scope ile gönderilir)
# Yoksa hem Gmail import hem reminder disabled.
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:4000/api/auth/callback/google
# Scope'lar: gmail.readonly + gmail.send (better-auth provider'ı içinde tanımlı)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Reminder timezone (cron için)
REMINDER_TZ=Europe/Istanbul
