{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM"]
  },
  "references": [{ "path": "../shared" }, { "path": "../api-client" }],
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
